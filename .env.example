# Shopify store domain (e.g. mystore.myshopify.com)
SHOPIFY_STORE_DOMAIN=

# Shopify Shop ID (numeric ID เช่น 95543656735 — หาได้จาก Settings > Customer accounts > URL)
SHOPIFY_SHOP_ID=

# Client ID จาก Customer Account API settings (Shopify Dev Dashboard)
SHOPIFY_CLIENT_ID=

# Client Secret จาก Customer Account API settings (for confidential client)
SHOPIFY_CLIENT_SECRET=

# URL ของ Next.js app นี้ (ใช้สำหรับ redirect_uri)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# iron-session secret — อย่างน้อย 32 ตัวอักษร
# Generate with: openssl rand -hex 32
SESSION_SECRET=

