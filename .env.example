# Shopify store domain (e.g. mystore.myshopify.com)
SHOPIFY_STORE_DOMAIN=

# Shopify Shop ID (numeric ID, e.g. 95543656735). Get it from Settings > Customer accounts > URL
SHOPIFY_SHOP_ID=

# Client ID from Customer Account API settings (Shopify Dev Dashboard)
SHOPIFY_CLIENT_ID=

# Client Secret from Customer Account API settings (for confidential client)
SHOPIFY_CLIENT_SECRET=

# URL of this Next.js app (used for redirect_uri)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# iron-session secret — at least 32 characters
# Generate with: openssl rand -hex 32
SESSION_SECRET=

# Resend API key (get from resend.com)
RESEND_API_KEY=

# Email sender address (must be verified domain in Resend)
RESEND_FROM_EMAIL=noreply@yourdomain.com

# CustomAuthenApp — Admin API credentials (used only for Admin API)
# From Shopify Dev Dashboard → CustomAuthenApp → Settings
SHOPIFY_ADMIN_CLIENT_ID=
SHOPIFY_ADMIN_CLIENT_SECRET=

#
# OIDC Custom Identity Provider (this app)
#
# IMPORTANT: You must configure these in Shopify's "Custom Identity Provider" settings.
OIDC_ISSUER=CustomAuth

# You generate these; then enter the SAME values in Shopify Admin → Customer accounts → Custom Identity Provider.
# Client ID: any unique string (e.g. shopify-custom-idp or a UUID).
# Client secret: generate with:  openssl rand -hex 32
OIDC_CLIENT_ID=bfbf8fcec8f40ae417031cbb2b909751
OIDC_CLIENT_SECRET=52120426c8ad6f7638cf8d4f78568bf48e72cc35f05acf4734f53fb53c1c3d47

# Strict redirect-uri allow-list (comma-separated).
# Must include the redirect_uri values Shopify sends to:
# - GET /api/oidc/authorize
OIDC_REDIRECT_URIS=https://shopify.com/authentication/95543656735/login/external/callback,https://john-transfer-store.account.myshopify.com/authentication/login/external/callback

# Optional: if Shopify calls logout with post_logout_redirect_uri.
OIDC_POST_LOGOUT_REDIRECT_URIS=https://ssdemo.store/customer_authentication/logout/callback,https://shopify.com/95543656735/account/logout_callback,https://john-transfer-store.account.myshopify.com/logout_callback

# Required for OIDC: RSA keypair so id_token signing and JWKS stay stable (no "Access token request error").
# Option A — use files (recommended): create .oidc-private.pem, then derive .oidc-public.pem FROM IT (same keypair).
#   openssl genrsa 2048 | openssl pkcs8 -topk8 -nocrypt -out .oidc-private.pem
#   openssl rsa -in .oidc-private.pem -pubout -out .oidc-public.pem
#   (Public MUST be extracted from the private file above; otherwise signature verification will fail.)
# Option B — use env (required on Vercel; .pem files are in .gitignore and are not deployed):
#   Paste full PEM into OIDC_PRIVATE_KEY and OIDC_PUBLIC_KEY. For newlines use \n in one line, or multi-line value in Vercel.
OIDC_PRIVATE_KEY=
OIDC_PUBLIC_KEY=
# Optional: custom paths to key files (default: .oidc-private.pem / .oidc-public.pem in project root)
# OIDC_PRIVATE_KEY_PATH=
# OIDC_PUBLIC_KEY_PATH=
# Optional: key id in JWT/JWKS (default: shopify-key-1)
# OIDC_KID=shopify-key-1

